{
  "name": "computational-physicalism-book",
  "version": "1.0.0",
  "description": "計算可能性理論と物理的制約の観点から、人間とAIの知能の等価性を探求する哲学的・技術的論考",
  "author": "太田和彦（株式会社アイティードゥ）",
  "license": "CC-BY-NC-SA-4.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node easy-setup.js",
    "build": "node scripts/build-simple.js",
    "check:build-determinism": "node scripts/check-build-determinism.js",
    "check:metadata": "node scripts/check-metadata-consistency.js",
    "check:claims": "node scripts/check-claim-class-contract.js --root .",
    "check:claims-regression": "node scripts/check-claim-class-contract-regression.js",
    "build:full": "node scripts/build.js",
    "preview": "npm run build && npx http-server docs -p 8080 --silent",
    "deploy": "bash scripts/deploy.sh",
    "clean": "rm -rf public output temp",
    "configure:workflows": "node scripts/configure-workflows.js",
    "lint:light": "markdownlint 'src/**/*.md' --ignore node_modules",
    "test:light": "npm run lint:light && npm run check:claims && npm run check:claims-regression && npm run build",
    "help": "echo 'Available commands:\n  npm run setup - Interactive setup\n  npm run build - Build the book\n  npm run preview - Local preview\n  npm run configure:workflows - Disable problematic workflows\n  npm run deploy - Deploy to GitHub Pages'",
    "check:security": "npm audit --omit=optional"
  },
  "dependencies": {
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "markdownlint-cli": "^0.48.0"
  },
  "keywords": [
    "book",
    "publishing",
    "markdown",
    "github-pages",
    "template",
    "easy-setup"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itdojp/computational-physicalism-book.git"
  },
  "bugs": {
    "url": "https://github.com/itdojp/computational-physicalism-book/issues"
  },
  "homepage": "https://itdojp.github.io/computational-physicalism-book/",
  "overrides": {
    "gray-matter": {
      "js-yaml": "4.3.0"
    },
    "markdownlint-cli": {
      "js-yaml": "4.3.0",
      "markdown-it": {
        ".": "14.2.0",
        "linkify-it": "5.0.1"
      }
    }
  }
}
